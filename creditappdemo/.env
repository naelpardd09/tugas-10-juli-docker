VITE_SCORING_MODE=mock
VITE_BACKEND_BASE_URL=http://localhost:8080
VITE_SCORING_PATH=/api/v1/credit-scoring/simulate
# Request JSON shape: aegira (snake_case, selaras Aegira Loan Service README) | kreditku (camelCase legacy)
VITE_SCORING_SCHEMA=aegira
# Untuk projected DSR (cicilan baru estimasi): plafon / tenor
VITE_SCORING_DEFAULT_TENURE=12
